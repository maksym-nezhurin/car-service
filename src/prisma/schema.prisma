generator client {
  provider = "prisma-client-js"
  // Isolated client — monorepo root @prisma/client is overwritten by other services
  output   = "../../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  parentId  String?  
  parent    Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryParent")

  attributes Attribute[]
  ads        Ad[]
}

model Ad {
  id          String     @id @default(uuid())
  title       String
  description String?
  price       Decimal    @db.Decimal(12,2)
  currency    String     @default("USD")
  userId      String
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])

  attributes  AttributeValue[]
  media       Media[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
}

model Attribute {
  id         String     @id @default(uuid())
  categoryId String
  name       String
  key        String?
  type       AttributeType
  unit       String?

  category   Category   @relation(fields: [categoryId], references: [id])
  values     AttributeValue[]
  options    AttributeOption[]

  @@unique([categoryId, name], name: "categoryId_name")
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
  ENUM
  DATE
}

model AttributeOption {
  id          String     @id @default(uuid())
  attributeId String
  value       String

  attribute   Attribute @relation(fields: [attributeId], references: [id])

  @@unique([attributeId, value], name: "attributeId_value")
}

model AttributeValue {
  id          String   @id @default(uuid())
  adId        String
  attributeId String
  value       String   // зберігаємо як текст, конвертуємо на рівні бізнес-логіки

  ad          Ad       @relation(fields: [adId], references: [id])
  attribute   Attribute @relation(fields: [attributeId], references: [id])
}

model Media {
  id        String   @id @default(uuid())
  adId      String
  url       String   // Cloudinary URL
  type      String   // image, video, etc.
  position  Int?

  ad        Ad       @relation(fields: [adId], references: [id])
}

model Vehicle {
  id                String                  @id @default(uuid())
  vin               String                  @unique
  year              Int?
  plateNumber       String?
  brandId           String?
  modelId           String?
  variantId         String?
  vehicleType       String?
  color             String?
  engine            String?
  transmission      String?
  fuelType          String?
  currentMileageKm  Int?
  countryCode       String?                 @default("PL")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  ownerships        VehicleOwnership[]
  photos            VehiclePhoto[]
  saleListings      VehicleSaleListing[]
  maintenance       MaintenanceRecord[]
  serviceVisits     GarageServiceVisit[]
  odometerLogs      OdometerLog[]
  registrationEvents VehicleRegistrationEvent[]
  technicalInspection VehicleTechnicalInspection?
  insurancePolicies   VehicleInsurancePolicy[]
  saleContracts     VehicleSaleContract[]
  reports           VehicleReport[]
  reportAccessGrants VehicleReportAccessGrant[]
  profileViewLogs   VehicleProfileViewLog[]

  @@index([brandId, modelId, variantId], name: "vehicle_brand_model_variant_idx")
}

model VehiclePhoto {
  id          String   @id @default(uuid())
  vehicleId   String
  ownerUserId String
  url         String
  publicId    String?
  createdAt   DateTime @default(now())

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt], name: "vehicle_photo_vehicle_idx")
}

enum SaleListingStatus {
  DRAFT
  READY
  ACTIVE
  PAUSED
  SOLD
  ARCHIVED
}

enum DistributionPlatform {
  OUR_SITE
  OTOMOTO
  FACEBOOK_MARKETPLACE
  OLX
  AUTOBAZAR_SK
  AUTORIA
  TIKTOK
  INSTAGRAM
}

enum ListingDistributionStatus {
  PENDING
  IN_PROGRESS
  PUBLISHED
  FAILED
  UNPUBLISHED
}

model VehicleSaleListing {
  id          String                  @id @default(uuid())
  vehicleId   String
  ownerUserId String
  status      SaleListingStatus       @default(DRAFT)
  title       String?
  description String?
  price       Decimal?                @db.Decimal(12,2)
  currency    String?                 @default("PLN")
  marketRegion String?
  specsJson   Json?
  appearanceJson Json?
  featuresJson Json?
  contactJson Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  vehicle     Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  distributions ListingDistribution[]

  @@index([vehicleId, ownerUserId], name: "sale_listing_vehicle_owner_idx")
}

model ListingDistribution {
  id           String                    @id @default(uuid())
  saleListingId String
  platform     DistributionPlatform
  status       ListingDistributionStatus @default(PENDING)
  externalId   String?
  externalUrl  String?
  lastError    String?
  payloadSnapshot Json?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  saleListing  VehicleSaleListing        @relation(fields: [saleListingId], references: [id], onDelete: Cascade)

  @@unique([saleListingId, platform], name: "sale_listing_platform_unique")
  @@index([saleListingId, status], name: "sale_distribution_status_idx")
}

enum VehicleProfileTier {
  PUBLIC
  OWNER
  PAID
}

enum VehicleReportStatus {
  PENDING
  READY
  FAILED
  EXPIRED
}

model VehicleReport {
  id         String             @id @default(uuid())
  vehicleId  String
  provider   String
  tier       VehicleProfileTier @default(PUBLIC)
  status     VehicleReportStatus @default(PENDING)
  summary    Json?
  rawPayload Json?
  fetchedAt  DateTime?
  expiresAt  DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  vehicle    Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, provider, tier], name: "vehicle_report_lookup_idx")
}

model VehicleReportAccessGrant {
  id          String             @id @default(uuid())
  vehicleId   String
  userId      String
  provider    String
  accessLevel VehicleProfileTier @default(PAID)
  source      String             @default("purchase")
  validUntil  DateTime?
  createdAt   DateTime           @default(now())

  vehicle     Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, userId, provider], name: "vehicle_report_access_lookup_idx")
}

model VehicleProfileViewLog {
  id            String             @id @default(uuid())
  vehicleId     String
  viewerUserId  String?
  requestedTier VehicleProfileTier @default(PUBLIC)
  resolvedTier  VehicleProfileTier @default(PUBLIC)
  meta          Json?
  createdAt     DateTime           @default(now())

  vehicle       Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt], name: "vehicle_profile_view_log_idx")
}

model OdometerLog {
  id           String   @id @default(uuid())
  vehicleId    String
  ownerUserId  String
  mileageKm    Int
  recordedAt   DateTime @default(now())
  notes        String?
  source       String   @default("manual")

  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, recordedAt], name: "odometer_vehicle_date_idx")
  @@index([vehicleId, mileageKm], name: "odometer_vehicle_mileage_idx")
}

model VehicleOwnership {
  id          String    @id @default(uuid())
  vehicleId   String
  ownerUserId String
  cloudFolder String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  isCurrent   Boolean   @default(true)
  isPrimary   Boolean   @default(false)
  source      String    @default("manual")
  createdAt   DateTime  @default(now())

  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, isCurrent], name: "ownership_owner_current_idx")
  @@index([ownerUserId, isPrimary], name: "ownership_owner_primary_idx")
  @@index([vehicleId, isCurrent], name: "ownership_vehicle_current_idx")
}

enum MaintenanceType {
  ENGINE_OIL
  OIL_FILTER
  AIR_FILTER
  CABIN_FILTER
  SPARK_PLUGS
  CLUTCH_REPLACEMENT
  BRAKE_PADS
  BRAKE_FLUID
  COOLANT
  TIMING_BELT
  TIRE_CHANGE
  OTHER
}

model MaintenanceRecord {
  id           String          @id @default(uuid())
  vehicleId    String
  ownerUserId  String
  type         MaintenanceType
  title        String
  details      String?
  mileageKm    Int
  performedAt  DateTime
  costAmount   Decimal?        @db.Decimal(12,2)
  costCurrency String?         @default("PLN")
  source       String          @default("manual")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  attachments  MaintenanceAttachment[]

  @@index([vehicleId, mileageKm], name: "maintenance_vehicle_mileage_idx")
  @@index([vehicleId, performedAt], name: "maintenance_vehicle_date_idx")
}

model MaintenanceAttachment {
  id                  String            @id @default(uuid())
  maintenanceRecordId String
  ownerUserId         String
  url                 String
  publicId            String?
  originalName        String?
  mimeType            String?
  sizeBytes           Int?
  createdAt           DateTime          @default(now())

  maintenanceRecord   MaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)

  @@index([maintenanceRecordId], name: "maintenance_attachment_record_idx")
}

enum VisitVerifiedBy {
  OWNER
  PARTNER
}

enum PartPurchasedBy {
  OWNER
  WORKSHOP
}

model GarageServiceVisit {
  id               String            @id @default(uuid())
  vehicleId        String            @map("vehicle_id")
  ownerUserId      String            @map("owner_user_id")
  performedAt      DateTime          @map("performed_at")
  odometerKm       Int?              @map("odometer_km")
  totalCost        Decimal?          @map("total_cost") @db.Decimal(12, 2)
  costCurrency     String?           @default("PLN") @map("cost_currency")
  notes            String?
  organizationId   String?           @map("organization_id")
  draftCompanyId   String?           @map("draft_company_id")
  providerSnapshot Json              @map("provider_snapshot")
  verifiedBy       VisitVerifiedBy   @default(OWNER) @map("verified_by")
  workOrderId      String?           @map("work_order_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  lineItems        GarageServiceLineItem[]
  attachments      GarageServiceVisitAttachment[]

  @@index([vehicleId, performedAt], name: "garage_visit_vehicle_date_idx")
  @@index([ownerUserId], name: "garage_visit_owner_idx")
  @@map("garage_service_visits")
}

model GarageServiceLineItem {
  id          String   @id @default(uuid())
  visitId     String   @map("visit_id")
  sortOrder   Int      @default(0) @map("sort_order")
  name        String
  description String?
  laborCost   Decimal? @map("labor_cost") @db.Decimal(12, 2)
  partsCost   Decimal? @map("parts_cost") @db.Decimal(12, 2)
  lineTotal   Decimal? @map("line_total") @db.Decimal(12, 2)

  visit       GarageServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  parts       GarageServicePart[]

  @@index([visitId, sortOrder], name: "garage_line_item_visit_idx")
  @@map("garage_service_line_items")
}

model GarageServicePart {
  id          String           @id @default(uuid())
  lineItemId  String           @map("line_item_id")
  name        String
  purchasedBy PartPurchasedBy  @map("purchased_by")
  brand       String?
  productUrl  String?          @map("product_url")
  partNumber  String?          @map("part_number")
  cost        Decimal?         @db.Decimal(12, 2)

  lineItem    GarageServiceLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@index([lineItemId], name: "garage_part_line_item_idx")
  @@map("garage_service_parts")
}

model GarageServiceVisitAttachment {
  id           String             @id @default(uuid())
  visitId      String             @map("visit_id")
  ownerUserId  String             @map("owner_user_id")
  url          String
  publicId     String?            @map("public_id")
  originalName String?            @map("original_name")
  mimeType     String?            @map("mime_type")
  sizeBytes    Int?               @map("size_bytes")
  createdAt    DateTime           @default(now()) @map("created_at")

  visit        GarageServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId], name: "garage_visit_attachment_visit_idx")
  @@map("garage_service_visit_attachments")
}

enum RegistrationEventType {
  REGISTERED
  DEREGISTERED
  OWNERSHIP_CHANGED
  IMPORTED
  EXPORTED
  OTHER
}

model VehicleRegistrationEvent {
  id          String                @id @default(uuid())
  vehicleId   String
  ownerUserId String
  eventType   RegistrationEventType
  eventDate   DateTime
  countryCode String?
  notes       String?
  createdAt   DateTime              @default(now())

  vehicle     Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, eventDate], name: "vehicle_registration_event_idx")
}

enum InsurancePolicyType {
  OC
  AC
}

model VehicleTechnicalInspection {
  id            String   @id @default(uuid())
  vehicleId     String   @unique @map("vehicle_id")
  ownerUserId   String   @map("owner_user_id")
  performedAt   DateTime @map("performed_at")
  validUntil    DateTime @map("valid_until")
  stationName   String?  @map("station_name")
  certificateNo String?  @map("certificate_no")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([ownerUserId], name: "vehicle_inspection_owner_idx")
  @@map("vehicle_technical_inspections")
}

model VehicleInsurancePolicy {
  id              String              @id @default(uuid())
  vehicleId       String              @map("vehicle_id")
  ownerUserId     String              @map("owner_user_id")
  type            InsurancePolicyType
  insurerName     String              @map("insurer_name")
  policyNumber    String?             @map("policy_number")
  startsAt        DateTime            @map("starts_at")
  endsAt          DateTime            @map("ends_at")
  premiumAmount   Decimal?            @map("premium_amount") @db.Decimal(12, 2)
  premiumCurrency String?             @default("PLN") @map("premium_currency")
  isActive        Boolean             @default(true) @map("is_active")
  notes           String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  vehicle         Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, type, isActive], name: "vehicle_insurance_vehicle_type_active_idx")
  @@map("vehicle_insurance_policies")
}

model VehicleSaleContract {
  id                String    @id @default(uuid())
  vehicleId         String
  sellerUserId      String
  buyerUserId       String?
  sellerSnapshot    Json
  buyerSnapshot     Json
  salePriceAmount   Decimal?  @db.Decimal(12,2)
  salePriceCurrency String?   @default("PLN")
  contractDate      DateTime
  generatedText     String
  status            String    @default("draft")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, contractDate], name: "vehicle_sale_contract_idx")
}

// ---------------------------------------------------------------------------
// Local vehicle catalog mirror (CarQuery → DB). Source of truth for community
// generations + variant subgroups. Do not call CarQuery on every user request.
// ---------------------------------------------------------------------------

model CatalogMake {
  id        String         @id
  slug      String         @unique
  name      String
  logoUrl   String?        @map("logo_url")
  syncedAt  DateTime       @default(now()) @map("synced_at")
  models    CatalogModel[]

  @@map("catalog_makes")
}

model CatalogModel {
  id          String              @id
  makeId      String              @map("make_id")
  slug        String
  name        String
  syncedAt    DateTime            @default(now()) @map("synced_at")
  make        CatalogMake         @relation(fields: [makeId], references: [id], onDelete: Cascade)
  generations CatalogGeneration[]

  @@unique([makeId, slug])
  @@map("catalog_models")
}

/// Model line / generation (community GENERATION room), e.g. Tucson 2015–2018.
model CatalogGeneration {
  id               String       @id @default(uuid())
  modelId          String       @map("model_id")
  externalModelId  String?      @map("external_model_id")
  slug             String
  displayName      String       @map("display_name")
  yearFrom         Int?         @map("year_from")
  yearTo           Int?         @map("year_to")
  coverImageUrl    String?      @map("cover_image_url")
  shortDescription String?      @map("short_description")
  isSupported      Boolean      @default(true) @map("is_supported")
  supportTier      String       @default("active") @map("support_tier")
  contentKey       String?      @unique @map("content_key")
  syncedAt         DateTime     @default(now()) @map("synced_at")
  model            CatalogModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  trims            CatalogTrim[]

  @@unique([modelId, slug])
  @@index([externalModelId])
  @@map("catalog_generations")
}

/// Engine subgroup (community VARIANT), e.g. 2.0 CRDi 185 KM — not trim package (Premium).
model CatalogTrim {
  id                   String                     @id
  generationId         String                     @map("generation_id")
  slug                 String
  displayName          String                     @map("display_name")
  modelYear            Int?                       @map("model_year")
  engine               String?
  fuelType             String?                    @map("fuel_type")
  aspiration           String?
  powerHp              Int?                       @map("power_hp")
  transmission         String?
  engineCode           String?                    @map("engine_code")
  displacementCc       Int?                       @map("displacement_cc")
  contentKey           String?                    @unique @map("content_key")
  engineFamilyId       String?                    @map("engine_family_id")
  transmissionFamilyId String?                    @map("transmission_family_id")
  syncedAt             DateTime                   @default(now()) @map("synced_at")
  generation           CatalogGeneration          @relation(fields: [generationId], references: [id], onDelete: Cascade)
  engineFamily         CatalogEngineFamily?       @relation(fields: [engineFamilyId], references: [id], onDelete: SetNull)
  transmissionFamily   CatalogTransmissionFamily? @relation(fields: [transmissionFamilyId], references: [id], onDelete: SetNull)

  @@unique([generationId, slug])
  @@index([engineFamilyId])
  @@index([transmissionFamilyId])
  @@map("catalog_trims")
}

/// Curated engine family KB (Phase C) — linked from trims, shared across models.
model CatalogEngineFamily {
  id               String        @id @default(uuid())
  slug             String        @unique
  displayName      String        @map("display_name")
  manufacturer     String?
  displacementCc   Int?          @map("displacement_cc")
  fuelType         String?       @map("fuel_type")
  aspiration       String?
  engineCodes      String[]      @default([]) @map("engine_codes")
  specsJson        Json?         @map("specs_json")
  shortDescription String?       @map("short_description")
  reviewStatus     String        @default("approved") @map("review_status")
  reviewedAt       DateTime?     @map("reviewed_at")
  source           String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  trims            CatalogTrim[]

  @@map("catalog_engine_families")
}

/// Curated transmission family KB (Phase C).
model CatalogTransmissionFamily {
  id               String        @id @default(uuid())
  slug             String        @unique
  displayName      String        @map("display_name")
  type             String?
  gears            Int?
  manufacturer     String?
  specsJson        Json?         @map("specs_json")
  shortDescription String?       @map("short_description")
  reviewStatus     String        @default("approved") @map("review_status")
  reviewedAt       DateTime?     @map("reviewed_at")
  source           String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  trims            CatalogTrim[]

  @@map("catalog_transmission_families")
}
